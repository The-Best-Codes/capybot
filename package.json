{
  "name": "capybot",
  "version": "0.3.0-beta.1",
  "private": true,
  "description": "CapyBot is CapyBot. He's indescribable.",
  "type": "module",
  "module": "index.ts",
  "scripts": {
    "start:bot": "discraft start",
    "start:dashboard": "cd dashboard && NODE_ENV=production bun src/index.ts",
    "start": "bun run start:bot & bun run start:dashboard",
    "dev:bot": "discraft dev",
    "dev:dashboard": "cd dashboard && bun --hot src/index.ts",
    "dev": "bun run dev:bot & bun run dev:dashboard",
    "build:bot": "discraft build",
    "build:dashboard": "cd dashboard && bun build.ts",
    "build": "bun run build:bot && bun run build:dashboard",
    "fmt": "oxfmt --write .",
    "fmt:check": "oxfmt --check .",
    "tsc": "tsc -b --noEmit --incremental",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix ."
  },
  "dependencies": {
    "@ai-sdk/google": "^4.0.10",
    "@ai-sdk/openai-compatible": "^3.0.6",
    "@clack/prompts": "^1.7.0",
    "@openrouter/ai-sdk-provider": "^3.0.0",
    "@radix-ui/react-label": "^2.1.11",
    "@radix-ui/react-select": "^2.3.3",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tabs": "^1.1.10",
    "ai": "^7.0.18",
    "bun-plugin-tailwind": "^0.1.2",
    "cheerio": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "commander": "^15.0.0",
    "consola": "^3.4.2",
    "discord.js": "^14.26.4",
    "dotenv": "^17.4.2",
    "fuzzysort": "^3.1.0",
    "lucide-react": "^1.23.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0",
    "turndown": "^7.2.4",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/turndown": "^5.0.6",
    "discraft": "^1.7.11",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "tailwindcss": "^4.3.2",
    "typescript": "^7.0.2"
  }
}
